function Elements.Button(parent, text, callback)
    local btn = create("TextButton", {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Theme.PanelBg,
        BackgroundTransparency = Theme.PanelTransparency,
        Text = text,
        TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium,
        TextSize = 13,
        AutoButtonColor = false,
    }, parent)
    create("UICorner", { CornerRadius = UDim.new(0, 8) }, btn)
    local scale = create("UIScale", { Scale = 1 }, btn)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Theme.Accent,
            BackgroundTransparency = 0,
        }):Play()
        TweenService:Create(scale, TweenInfo.new(0.15, Enum.EasingStyle.Quad), { Scale = 1.02 }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Theme.PanelBg,
            BackgroundTransparency = Theme.PanelTransparency,
        }):Play()
        TweenService:Create(scale, TweenInfo.new(0.15, Enum.EasingStyle.Quad), { Scale = 1 }):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(scale, TweenInfo.new(0.08, Enum.EasingStyle.Quad), { Scale = 0.95 }):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(scale, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1.02 }):Play()
    end)
    btn.MouseButton1Click:Connect(function()
        callback()
    end)
    return btn
end

function Elements.Toggle(parent, text, default, callback)
    local row = create("Frame", { Size = UDim2.new(1, 0, 0, 24), BackgroundTransparency = 1 }, parent)
    create("TextLabel", {
        Size = UDim2.new(1, -50, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.Text,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, row)
    local track = create("Frame", {
        Size = UDim2.new(0, 40, 0, 22),
        Position = UDim2.new(1, -40, 0.5, -11),
        BackgroundColor3 = default and Theme.Accent or Theme.TrackBg,
    }, row)
    create("UICorner", { CornerRadius = UDim.new(1, 0) }, track)
    addStroke(track, 1)
    local knob = create("Frame", {
        Size = UDim2.new(0, 18, 0, 18),
        Position = default and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9),
        BackgroundColor3 = Theme.Knob,
    }, track)
    create("UICorner", { CornerRadius = UDim.new(1, 0) }, knob)
    local knobScale = create("UIScale", { Scale = 1 }, knob)
    local hitbox = create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "" }, track)
    local state = default
    local toggleId = "toggle_" .. tostring(tick()) .. "_" .. tostring(math.random(1, 1000000))
    if state then
        _G.LuniToggleRegistry[toggleId] = { callback = callback }
    end
    hitbox.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(track, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
            BackgroundColor3 = state and Theme.Accent or Theme.TrackBg,
        }):Play()
        TweenService:Create(knob, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9),
        }):Play()
        local bounce = TweenService:Create(knobScale, TweenInfo.new(0.1, Enum.EasingStyle.Quad), { Scale = 1.25 })
        bounce:Play()
        bounce.Completed:Connect(function()
            TweenService:Create(knobScale, TweenInfo.new(0.12, Enum.EasingStyle.Quad), { Scale = 1 }):Play()
        end)
        if state then
            _G.LuniToggleRegistry[toggleId] = { callback = callback }
        else
            _G.LuniToggleRegistry[toggleId] = nil
        end
        callback(state)
    end)
end

function Elements.Keybind(parent, text, defaultKey, callback)
    local row = create("Frame", { Size = UDim2.new(1, 0, 0, 24), BackgroundTransparency = 1 }, parent)
    create("TextLabel", {
        Size = UDim2.new(1, -70, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.Text,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, row)
    local keyBtn = create("TextButton", {
        Size = UDim2.new(0, 60, 0, 22),
        Position = UDim2.new(1, -60, 0.5, -11),
        BackgroundColor3 = Theme.PanelBg,
        BackgroundTransparency = Theme.PanelTransparency,
        Text = defaultKey,
        TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
    }, row)
    create("UICorner", { CornerRadius = UDim.new(0, 6) }, keyBtn)
    addStroke(keyBtn, 1)

    local currentKey = defaultKey
    local state = false
    local listening = false
    local toggleId = "keybind_" .. tostring(tick()) .. "_" .. tostring(math.random(1, 1000000))

    keyBtn.MouseButton1Click:Connect(function()
        listening = true
        keyBtn.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
        if listening then
            currentKey = input.KeyCode.Name
            keyBtn.Text = currentKey
            listening = false
            return
        end
        if processed then return end
        if input.KeyCode.Name == currentKey then
            state = not state
            if state then
                _G.LuniToggleRegistry[toggleId] = { callback = callback }
            else
                _G.LuniToggleRegistry[toggleId] = nil
            end
            callback(state)
        end
    end)
end

