function Luni:CreateWindow(title, themeName)
    Theme = Themes[themeName] or Themes.dark

    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")
    local existing = playerGui:FindFirstChild("LuniUI")
    if existing then
        existing:Destroy()
    end

    for _, entry in pairs(_G.LuniToggleRegistry) do
        pcall(entry.callback, false)
    end
    _G.LuniToggleRegistry = {}

    local MIN_HEIGHT = 84
    local viewportHeight = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.Y or 800
    local MAX_HEIGHT = math.clamp(viewportHeight - 120, 300, 620)

    local ScreenGui = create("ScreenGui", {
        Name = "LuniUI",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    }, playerGui)
    local targetPosition = UDim2.new(1, -340, 0.5, -210)
    local Main = create("Frame", {
        Size = UDim2.new(0, 320, 0, MIN_HEIGHT),
        Position = UDim2.new(1, 40, 0.5, -210),
        BackgroundColor3 = Theme.MainBg,
        BackgroundTransparency = Theme.MainTransparency,
        BorderSizePixel = 0,
    }, ScreenGui)
    create("UICorner", { CornerRadius = UDim.new(0, 12) }, Main)
    addStroke(Main, 1, Theme.Border, Theme.BorderTransparency - 0.03)
    local TitleBar = create("Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = Theme.HeaderBg,
        BackgroundTransparency = Theme.MainTransparency,
        BorderSizePixel = 0,
    }, Main)
    create("UICorner", { CornerRadius = UDim.new(0, 12) }, TitleBar)
    create("TextLabel", {
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, TitleBar)
    do
        local dragging, dragStart, startPos
        TitleBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = Main.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
    end
    local TabBar = create("Frame", {
        Size = UDim2.new(1, -20, 0, 30),
        Position = UDim2.new(0, 10, 0, 48),
        BackgroundTransparency = 1,
        Visible = false,
    }, Main)
    create("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 6) }, TabBar)
    local Content = create("ScrollingFrame", {
        Size = UDim2.new(1, -20, 0, 0),
        Position = UDim2.new(0, 10, 0, 50),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 5,
        ScrollBarImageColor3 = Theme.Accent,
        ScrollBarImageTransparency = 0.3,
        BorderSizePixel = 0,
    }, Main)
    local ContentLayout = create("UIListLayout", { Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder }, Content)

    local tabContainers = {}

    local function resize()
        local top = TabBar.Visible and 84 or 50
        local activeContainer = Content
        local layout = ContentLayout
        if TabBar.Visible then
            for _, c in ipairs(tabContainers) do
                if c.Visible then
                    activeContainer = c
                    layout = c:FindFirstChildOfClass("UIListLayout")
                    break
                end
            end
        end
        if not layout then return end
        local desired = math.clamp(top + layout.AbsoluteContentSize.Y + 16, MIN_HEIGHT, MAX_HEIGHT)
        TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, 320, 0, desired),
        }):Play()
        TweenService:Create(activeContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Size = UDim2.new(1, -20, 0, desired - top - 10),
        }):Play()
    end

    ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(resize)

    TweenService:Create(Main, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = targetPosition,
    }):Play()

    local self = setmetatable({
        _frame = Main,
        _content = Content,
        _tabBar = TabBar,
        _tabButtons = {},
        _tabContainers = tabContainers,
        _resize = resize,
    }, Window)

    task.defer(resize)

    if _G.LuniRespawnConnection then
        _G.LuniRespawnConnection:Disconnect()
    end
    _G.LuniRespawnConnection = player.CharacterAdded:Connect(function()
        task.wait(1)
        for _, entry in pairs(_G.LuniToggleRegistry) do
            pcall(entry.callback, true)
        end
    end)

    return self
end

return Luni
