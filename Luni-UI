function Elements.ProgressBar(parent, text, min, max, refreshSeconds, getValue)
    local wrap = create("Frame", { Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1 }, parent)
    local label = create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.Text,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, wrap)
    local track = create("Frame", {
        Size = UDim2.new(1, 0, 0, 8),
        Position = UDim2.new(0, 0, 0, 26),
        BackgroundColor3 = Theme.TrackBg,
    }, wrap)
    create("UICorner", { CornerRadius = UDim.new(1, 0) }, track)
    addStroke(track, 1)
    local fill = create("Frame", { Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = Theme.Accent }, track)
    create("UICorner", { CornerRadius = UDim.new(1, 0) }, fill)

    task.spawn(function()
        while wrap.Parent do
            local ok, value = pcall(getValue)
            if ok and type(value) == "number" then
                local ratio = math.clamp((value - min) / (max - min), 0, 1)
                TweenService:Create(fill, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                    Size = UDim2.new(ratio, 0, 1, 0),
                }):Play()
                label.Text = text .. ": " .. tostring(value)
            end
            task.wait(refreshSeconds)
        end
    end)
end

