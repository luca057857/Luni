    if not self._tabBar.Visible then
        self._tabBar.Visible = true
        self._content.Visible = false
    end
    local container = create("ScrollingFrame", {
        Size = UDim2.new(1, -20, 0, 0),
        Position = UDim2.new(0, 10, 0, 84),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 5,
        ScrollBarImageColor3 = Theme.Accent,
        ScrollBarImageTransparency = 0.3,
        BorderSizePixel = 0,
        Visible = isFirst,
    }, self._frame)
    local layout = create("UIListLayout", { Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder }, container)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if container.Visible and self._resize then
            self._resize()
        end
    end)
    local tabBtn = create("TextButton", {
        Size = UDim2.new(0, 90, 1, 0),
        BackgroundColor3 = isFirst and Theme.Accent or Theme.PanelBg,
        BackgroundTransparency = isFirst and 0 or Theme.PanelTransparency,
        Text = name,
        TextColor3 = Theme.Text,
        Font = Enum.Font.Gotham,
        TextSize = 12,
    }, self._tabBar)
    create("UICorner", { CornerRadius = UDim.new(0, 6) }, tabBtn)
    addStroke(tabBtn, 1)
    table.insert(self._tabButtons, tabBtn)
    table.insert(self._tabContainers, container)
    tabBtn.MouseButton1Click:Connect(function()
        for _, c in ipairs(self._tabContainers) do
            if c ~= container then
                c.Visible = false
            end
        end
        for _, b in ipairs(self._tabButtons) do
            if b ~= tabBtn then
                TweenService:Create(b, TweenInfo.new(0.15), {
                    BackgroundColor3 = Theme.PanelBg,
                    BackgroundTransparency = Theme.PanelTransparency,
                }):Play()
            end
        end
        container.Visible = true
        TweenService:Create(tabBtn, TweenInfo.new(0.15), {
            BackgroundColor3 = Theme.Accent,
            BackgroundTransparency = 0,
        }):Play()
        if self._resize then
            self._resize()
        end
    end)
    if isFirst and self._resize then
        task.defer(self._resize)
    end
    return setmetatable({ _container = container }, Tab)
end

