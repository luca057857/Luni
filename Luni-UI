function Elements.Slider(parent, text, min, max, default, callback)
    local wrap = create("Frame", { Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1 }, parent)
    local label = create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = text .. ": " .. tostring(default),
        TextColor3 = Theme.Text,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, wrap)
    local track = create("Frame", {
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0, 26),
        BackgroundColor3 = Theme.TrackBg,
    }, wrap)
    create("UICorner", { CornerRadius = UDim.new(1, 0) }, track)
    addStroke(track, 1)
    local ratio = (default - min) / (max - min)
    local fill = create("Frame", { Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = Theme.Accent }, track)
    create("UICorner", { CornerRadius = UDim.new(1, 0) }, fill)
    local knob = create("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(ratio, 0, 0.5, 0),
        BackgroundColor3 = Theme.Knob,
    }, track)
    create("UICorner", { CornerRadius = UDim.new(1, 0) }, knob)
    TweenService:Create(fill, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(ratio, 0, 1, 0),
    }):Play()
    local dragging = false
    local function update(input, animated)
        local relX = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local tweenInfo = TweenInfo.new(animated and 0.12 or 0.02, Enum.EasingStyle.Quad)
        TweenService:Create(fill, tweenInfo, { Size = UDim2.new(relX, 0, 1, 0) }):Play()
        TweenService:Create(knob, tweenInfo, { Position = UDim2.new(relX, 0, 0.5, 0) }):Play()
        local value = math.floor(min + (max - min) * relX)
        label.Text = text .. ": " .. tostring(value)
        callback(value)
    end
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(input, true)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input, false)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

function Elements.Dropdown(parent, text, options, default, callback)
    local wrap = create("Frame", { Size = UDim2.new(1, 0, 0, 44), BackgroundTransparency = 1, ClipsDescendants = false }, parent)
    create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.Text,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, wrap)
    local box = create("TextButton", {
        Size = UDim2.new(1, 0, 0, 26),
        Position = UDim2.new(0, 0, 0, 18),
        BackgroundColor3 = Theme.PanelBg,
        BackgroundTransparency = Theme.PanelTransparency,
        Text = default,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
        Font = Enum.Font.Gotham,
        TextSize = 13,
    }, wrap)
    create("UICorner", { CornerRadius = UDim.new(0, 6) }, box)
    addStroke(box, 1)
    create("UIPadding", { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 26) }, box)
    local arrow = create("TextLabel", {
        Size = UDim2.new(0, 16, 1, 0),
        Position = UDim2.new(1, -20, 0, 0),
        BackgroundTransparency = 1,
        Text = "v",
        TextColor3 = Theme.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 11,
    }, box)
    local fullHeight = #options * 26
    local list = create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 46),
        BackgroundColor3 = Theme.PanelBg,
        BackgroundTransparency = Theme.PanelTransparency,
        ClipsDescendants = true,
        Visible = false,
        ZIndex = 5,
    }, wrap)
    create("UICorner", { CornerRadius = UDim.new(0, 6) }, list)
    addStroke(list, 1)
    create("UIListLayout", {}, list)
    local open = false
    for _, option in ipairs(options) do
        local opt = create("TextButton", {
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundTransparency = 1,
            Text = option,
            TextColor3 = Theme.Text,
            Font = Enum.Font.Gotham,
            TextSize = 13,
            ZIndex = 6,
        }, list)
        opt.MouseEnter:Connect(function()
            TweenService:Create(opt, TweenInfo.new(0.1), { BackgroundTransparency = 0.85 }):Play()
        end)
        opt.MouseLeave:Connect(function()
            TweenService:Create(opt, TweenInfo.new(0.1), { BackgroundTransparency = 1 }):Play()
        end)
        opt.MouseButton1Click:Connect(function()
            box.Text = option
            open = false
            local closeTween = TweenService:Create(list, TweenInfo.new(0.15, Enum.EasingStyle.Quad), { Size = UDim2.new(1, 0, 0, 0) })
            closeTween:Play()
            closeTween.Completed:Connect(function()
                list.Visible = false
            end)
            TweenService:Create(arrow, TweenInfo.new(0.15), { Rotation = 0 }):Play()
            callback(option)
        end)
    end
    box.MouseButton1Click:Connect(function()
        open = not open
        if open then
            list.Visible = true
            TweenService:Create(list, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.new(1, 0, 0, fullHeight),
            }):Play()
            TweenService:Create(arrow, TweenInfo.new(0.18), { Rotation = 180 }):Play()
        else
            local closeTween = TweenService:Create(list, TweenInfo.new(0.15, Enum.EasingStyle.Quad), { Size = UDim2.new(1, 0, 0, 0) })
            closeTween:Play()
            closeTween.Completed:Connect(function()
                list.Visible = false
            end)
            TweenService:Create(arrow, TweenInfo.new(0.15), { Rotation = 0 }):Play()
        end
    end)
end

